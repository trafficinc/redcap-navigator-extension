{
  "manifest_version": 3,
  "name": "REDCap Navigator",
  "description": "Quick navigation tools for REDCap projects and records.",
  "version": "2.0.0",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "REDCap Navigator"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "settings.html"
}